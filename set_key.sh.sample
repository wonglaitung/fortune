# Configuration file for environment variables
# Copy this file to set_key.sh and fill in your actual values

# Email Configuration
export SMTP_SERVER=smtp.163.com
export EMAIL_SENDER=xxx@163.com
export EMAIL_PASSWORD=xxx
export RECIPIENT_EMAIL=xxx@gmail.com,xxx@ic.com

# LLM Configuration
export QWEN_API_KEY=sk-ccxxx
export QWEN_CHAT_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
export QWEN_CHAT_MODEL=qwen-plus-2025-12-01

# WeChat Work Bot Configuration (Optional)
# Get webhook URL from: 企业微信群设置 -> 群机器人 -> 添加机器人
export WECHAT_WORK_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY

# WxPusher Configuration (Optional, alternative to WeChat Work)
# Create app at https://wxpusher.zjiecode.com/ and get appToken
# Scan QR code to follow app and get UID
export WXPUSHER_TOKEN=AT_xxx
export WXPUSHER_UIDS=UID_xxx,UID_yyy

echo "Configuration loaded successfully"
echo "QWEN_API_KEY: $QWEN_API_KEY"
